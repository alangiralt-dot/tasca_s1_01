* {
  box-sizing: border-box;
  /*outline: 1px solid black;*/
}
body {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin: 0 auto;
  max-width: 1200px;
}
/*-----------------------*/
header, main, footer {
  background-color: black;
  padding: 10px;
}
header, main {
  display: flex;
  gap: 10px;
}
header {
  flex-direction: column;
}

.logo, .nav, .social, .banner, .article, .navigation, .publicity, .foot {
    padding: 5px;
}
/*-----------------------*/
#div1 {
  align-items:center;
  background-color: darkslateblue;
  display: flex;
  gap: 10px;
  padding: 10px;
}
#div2 {
  background-color: orange;
  padding: 10px;
}
.logo {
  background-color: lightcoral;
  flex: 0 0 auto;
}
.nav {
  background-color: lightcoral;
  flex: 1 1 auto;
}
.social {
  background-color: lightcoral;
  flex: 0 0 auto;
}
.banner {
  background-color: gold;
}
/*-----------------------*/
#div3 {
  background-color: navy;
  display: grid;
  flex: 1 1 auto;
  gap: 10px;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: 1fr 1fr auto;
  padding: 10px;
}
#div4 {
  background-color: lightcoral;
  display: flex;
  flex: 0 0 auto;
  flex-direction: column;
  gap: 10px;
  padding: 10px;
  width: 160px;
}
.article {
  background-color: cornflowerblue;
}
.navigation {
  background-color: lightblue;
  grid-column: 1/3;
}
.publicity {
  background-color: gold;
}

/*-----------------------*/
.foot {
  background-color: burlywood;
}